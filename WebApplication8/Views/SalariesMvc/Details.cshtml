@model WebApplication8.Models.Salary

@{
    ViewData["Title"] = "Salary Details";
}

<h1>Salary Details</h1>
<dl class="row">
    <dt class="col-sm-2">Id</dt>
    <dd class="col-sm-10">@Model.Id</dd>

    <dt class="col-sm-2">Employee</dt>
    <dd class="col-sm-10">@Model.Employee?.Name</dd>

    <dt class="col-sm-2">Amount</dt>
    <dd class="col-sm-10">@Model.Amount</dd>

    <dt class="col-sm-2">Currency</dt>
    <dd class="col-sm-10">@Model.Currency</dd>

    <dt class="col-sm-2">Effective Date</dt>
    <dd class="col-sm-10">@Model.EffectiveDate.ToShortDateString()</dd>

    <dt class="col-sm-2">Note</dt>
    <dd class="col-sm-10">@Model.Note</dd>
</dl>
<p>
    <a class="btn btn-secondary" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
    <a class="btn btn-primary" asp-action="Index">Back to list</a>
</p>
